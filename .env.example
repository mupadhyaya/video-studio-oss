# Video Studio OSS Configuration

# The name of your learning series (Used in title slide and folders)
SERIES_NAME="OSS Tech Learning"

# Your Gemini API Key for generating scripts and lesson content
GEMINI_API_KEY="your-gemini-api-key-here"

# (Optional) Your YouTube OAuth Token to automatically upload videos
# If not provided, videos will just be generated locally.
YOUTUBE_OAUTH_TOKEN='{"token": "your-access-token", "refresh_token": "your-refresh-token", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "your-client-id", "client_secret": "your-client-secret", "scopes": ["https://www.googleapis.com/auth/youtube.upload"]}'
